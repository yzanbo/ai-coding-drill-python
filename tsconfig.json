// リポジトリルート用 tsconfig.json
// ルート配置の TS 設定ファイル（commitlint.config.ts、将来の .syncpackrc.ts 等）の
// 型チェック専用。workspace 用の tsconfig は各 apps / packages 配下に別途配置する。
//
// このファイルは拡張子 `.json` だが、TypeScript コンパイラが JSONC として解釈するため
// `//` コメントが書ける。ecosystem 慣習で `tsconfig.json` の名前は固定（tsc の自動探索が
// この名前を要求するため改名不可）。詳細・他の例外ファイルは ADR 0028 を参照。

{
  "compilerOptions": {
    // Node.js が解釈する最新 ECMAScript 機能を利用可能にする。
    "target": "ESNext",

    // Node.js の ESM/CJS 解決ルールに沿って .ts を読み込む。
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    // 型安全のメリットを最大化するため strict mode を有効化
    // （noImplicitAny / strictNullChecks 等まとめて on）。
    "strict": true,

    // JS 出力は不要、型チェックのみを目的とする。
    "noEmit": true,

    // CommonJS モジュール（@commitlint/types 等）の default import を許容。
    "esModuleInterop": true,

    // node_modules 内の .d.ts は信頼してチェックをスキップ（ビルド時間短縮）。
    "skipLibCheck": true,

    // JSON ファイルの直接 import を許可（将来の package.json 参照等に備える）。
    "resolveJsonModule": true
  },

  // include パターン：ルート直下の TS ファイルを 2 種類の glob で網羅する。
  //
  //   "*.ts"   通常 TS ファイル
  //              対象例：commitlint.config.ts / 将来の vitest.config.ts 等
  //
  //   ".*.ts"  dotfile TS ファイル
  //              対象例：.syncpackrc.ts 等
  //              なぜ別パターンが必要か：
  //                TypeScript の include glob は POSIX 慣習に従い `*` が `.` 始まりの
  //                ファイル名を拾わない。dotfile を対象に含めるには明示パターンが必須。
  //
  // 範囲制限：ルート直下のみ（再帰しない）。
  //   workspace 配下（apps/ / packages/）の TS ファイルは各 workspace の tsconfig が担当する。
  //   workspace 用の型チェックは Turborepo 経由で `pnpm typecheck` から呼ばれる。
  //
  // 保守性：新規 TS 設定ファイルが上記 2 パターンのいずれかに該当すれば自動的に対象になるため、
  //   ファイル追加のたびに include を編集する手間は不要。
  "include": ["*.ts", ".*.ts"]
}
