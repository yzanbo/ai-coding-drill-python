{
  "name": "ai-coding-drill",
  "version": "0.0.0",
  "description": "LLM が自動生成したプログラミング問題をサンドボックスで動作保証してから提供する TypeScript 練習サービス",
  "private": true,
  "license": "MIT",
  "author": "Yohei Jinbo",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.20.0",
    "pnpm": "9.15.4"
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo run test",
    "typecheck": "tsc --noEmit -p tsconfig.json && turbo run typecheck",
    "commitlint": "commitlint",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches",
    "syncpack:format": "syncpack format",
    "g-clean": "bash scripts/cleanup-merged-branches.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "lefthook": "^2.1.6",
    "syncpack": "^15.0.0",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3"
  }
}
