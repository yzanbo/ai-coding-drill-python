# peerDependencies を自動でインストール（pnpm v7+ の既定だが明示）。
auto-install-peers=true

# peer のバージョン不一致をエラーではなく警告に留める。
# モノレポ立ち上げ期は依存衝突が起きやすいため緩める。安定後は true に戻すのが理想。
strict-peer-dependencies=false

# 依存解決方式を isolated（pnpm 標準）に固定。
# node_modules/.pnpm/ に実体を 1 つ置き各パッケージから symlink する方式で、
# package.json に書いていないパッケージを import してしまう「ファントム依存」を防ぐ。
node-linker=isolated
