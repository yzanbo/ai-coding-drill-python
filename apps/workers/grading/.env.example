# apps/workers/grading 用の環境変数テンプレート（コピーして .env を作成）。
# caarlos0/env が変数名を case-sensitive で読むため、大文字スネークケースで書く。
#
# 使い方:
#   cp apps/workers/grading/.env.example apps/workers/grading/.env
#   # .env を編集して GOOGLE_API_KEY 等を埋める
#   mise run worker:grading:dev
#
# mise.toml の [env] _.file 設定で本ファイル (apps/workers/grading/.env) が
# mise run 経由のタスク起動時に自動 load される (ADR 0039)。

# ---------- Postgres ----------
# 採点ジョブ取得 + 結果書き戻しに使う (ADR 0004)。
# api 側 (SQLAlchemy 2.0) と env を共有するため SA 形式 (postgresql+asyncpg://) で揃える。
# worker (Go / pgx) は config.normalizeDatabaseURL で "+asyncpg" を strip して読む。
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_coding_drill

# ---------- Worker 動作パラメータ ----------
# 空欄なら main 側で os.Hostname() にフォールバックする (cmd/grading/main.go)。
WORKER_ID=

# 並列 goroutine 数 (> 0 必須、既定 4)。
WORKER_CONCURRENCY=4

# 採点コンテナの image タグ (両 Worker で同じ image を起動、ADR 0009)。
SANDBOX_IMAGE=ai-coding-drill-sandbox:latest

# 1 ジョブのタイムアウト秒 (> 0 必須、grading 既定 5)。
JOB_TIMEOUT_SECONDS=5

# locked_at がこの分数を超えたジョブを queued に戻す閾値 (> 0 必須、既定 5)。
RECLAIM_AFTER_MINUTES=5

# ---------- LLM ----------
# llm.yaml のパス (既定 apps/workers/grading/llm.yaml、ADR 0007 / ADR 0049)。
# 相対パスは Worker 起動時の working dir 基準で解決される。
LLM_CONFIG_PATH=llm.yaml

# provider 別 API キー。使う provider 分だけ埋めれば足りる。
# Google Gemini: https://aistudio.google.com/apikey で取得 (無料枠あり、ADR 0049)。
# 取得後は AIzaSy... の文字列をそのまま貼る (引用符不要)。
GOOGLE_API_KEY=

# 以下は R2 ベンチマーク開始時に別ベンダー Judge を有効化する時に埋める。
# MVP (R1〜R2 開始前) は Gemini 単独運用のため空でよい (ADR 0049 §例外保留)。
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
