{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthCheckResponse": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "created_at"
        ],
        "title": "HealthCheckResponse",
        "type": "object"
      },
      "UserResponse": {
        "description": "現在ログイン中のユーザー情報。GET /auth/me が返す形。\n\nsnake_case のモデル属性を camelCase で JSON 出力するよう alias を効かせる\n（Frontend の Hey API 生成型もそのまま camelCase になる）。",
        "properties": {
          "displayName": {
            "title": "Displayname",
            "type": "string"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "displayName"
        ],
        "title": "UserResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "AI Coding Drill API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/auth/github": {
      "get": {
        "description": "OAuth フロー開始。state を発行し GitHub の認可画面へ 302 リダイレクトする。\n\nクエリ:\n  - next: ログイン後の戻り先（同一オリジン相対パスのみ）。state レコードに\n          同梱して Redis に保存し、callback 側で 1 回使い切りで取り出す。\n          旧実装は別 Cookie（auth_next）で運んでいたが「state と next が\n          別場所に分かれて弱く結合」する設計弱点があったため state レコード\n          側に集約した。",
        "operationId": "start_github_oauth_auth_github_get",
        "parameters": [
          {
            "in": "query",
            "name": "next",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Next"
            }
          }
        ],
        "responses": {
          "302": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "GitHub 認可画面へリダイレクト"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Start Github Oauth",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/github/callback": {
      "get": {
        "description": "GitHub からのコールバック。\n\n成功時：Set-Cookie で sid / csrf_token を発行してホーム（または ?next= 指定先）へ 302。\nstate 不一致 / 期限切れ / 再使用：/login?auth_error=state_invalid へ 302。\nGitHub が ?error= を返した時：/login?auth_error=oauth_canceled へ 302。\nその他例外：/login?auth_error=oauth_failed へ 302。",
        "operationId": "github_callback_auth_github_callback_get",
        "parameters": [
          {
            "in": "query",
            "name": "code",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Code"
            }
          },
          {
            "in": "query",
            "name": "state",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "State"
            }
          },
          {
            "in": "query",
            "name": "error",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Error"
            }
          }
        ],
        "responses": {
          "302": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "ログイン成功はホーム /、失敗は /login へリダイレクト"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Github Callback",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "description": "セッションを破棄し、Cookie を Max-Age=0 で消す。\n\n- 内部的に Redis から `session:<sid>` を DELETE + `user:<id>:sessions` から SREM\n- 204 No Content（ボディなし）。Cookie だけがレスポンスヘッダーに残る",
        "operationId": "logout_auth_logout_post",
        "responses": {
          "204": {
            "description": "ログアウト成功（ボディなし）"
          }
        },
        "summary": "Logout",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "description": "ログイン中のユーザー情報を返す。未認証なら 401（get_current_user が投げる）。",
        "operationId": "get_me_auth_me_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Me",
        "tags": [
          "auth"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "直近 10 件を新しい順に返す。",
        "operationId": "list_health_checks_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/HealthCheckResponse"
                  },
                  "title": "Response List Health Checks Health Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Health Checks",
        "tags": [
          "health"
        ]
      },
      "post": {
        "description": "DB に 1 行追加して、追加した行を返す。",
        "operationId": "create_health_check_health_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Create Health Check",
        "tags": [
          "health"
        ]
      }
    },
    "/healthz": {
      "get": {
        "description": "liveness probe（DB 接続なし）。プロセスが生きていることだけを返す。",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Healthz Healthz Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Healthz",
        "tags": [
          "probes"
        ]
      }
    }
  }
}
