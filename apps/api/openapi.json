{
  "components": {
    "schemas": {
      "GenerationStatus": {
        "enum": [
          "pending",
          "completed",
          "failed"
        ],
        "title": "GenerationStatus",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthCheckResponse": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "created_at"
        ],
        "title": "HealthCheckResponse",
        "type": "object"
      },
      "ProblemCategory": {
        "enum": [
          "string",
          "array",
          "recursion",
          "async",
          "type-puzzle"
        ],
        "title": "ProblemCategory",
        "type": "string"
      },
      "ProblemDetailResponse": {
        "description": "問題詳細。テストケースの一部のみ examples として公開する。",
        "properties": {
          "category": {
            "$ref": "#/components/schemas/ProblemCategory"
          },
          "description": {
            "title": "Description",
            "type": "string"
          },
          "difficulty": {
            "$ref": "#/components/schemas/ProblemDifficulty"
          },
          "examples": {
            "items": {
              "$ref": "#/components/schemas/ProblemExample"
            },
            "title": "Examples",
            "type": "array"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "examples",
          "category",
          "difficulty"
        ],
        "title": "ProblemDetailResponse",
        "type": "object"
      },
      "ProblemDifficulty": {
        "enum": [
          "easy",
          "medium",
          "hard"
        ],
        "title": "ProblemDifficulty",
        "type": "string"
      },
      "ProblemExample": {
        "description": "画面表示用の入出力例。input / output は表示用の文字列。",
        "properties": {
          "input": {
            "title": "Input",
            "type": "string"
          },
          "output": {
            "title": "Output",
            "type": "string"
          }
        },
        "required": [
          "input",
          "output"
        ],
        "title": "ProblemExample",
        "type": "object"
      },
      "ProblemGenerateAcceptedResponse": {
        "description": "生成リクエスト受付完了。クライアントは requestId でポーリングを始める。",
        "properties": {
          "requestId": {
            "format": "uuid",
            "title": "Requestid",
            "type": "string"
          },
          "status": {
            "const": "pending",
            "default": "pending",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "requestId"
        ],
        "title": "ProblemGenerateAcceptedResponse",
        "type": "object"
      },
      "ProblemGenerateRequest": {
        "description": "問題生成リクエストの入力。\n\ncategory / difficulty とも Literal 縛りで MVP の許容値以外は 422 を返す\n（バリデーションは Pydantic が SSoT、problem-generation.md §バリデーション）。",
        "properties": {
          "category": {
            "$ref": "#/components/schemas/ProblemCategory"
          },
          "difficulty": {
            "$ref": "#/components/schemas/ProblemDifficulty"
          }
        },
        "required": [
          "category",
          "difficulty"
        ],
        "title": "ProblemGenerateRequest",
        "type": "object"
      },
      "ProblemGenerateStatusResponse": {
        "description": "生成リクエストの現在ステータス。completed の時のみ problemId を含む。",
        "properties": {
          "problemId": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Problemid"
          },
          "requestId": {
            "format": "uuid",
            "title": "Requestid",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/GenerationStatus"
          }
        },
        "required": [
          "requestId",
          "status"
        ],
        "title": "ProblemGenerateStatusResponse",
        "type": "object"
      },
      "ProblemListResponse": {
        "description": "問題一覧 + ページネーション情報。\n\n一覧クエリ単発で SSoT が固定されており、PaginationMeta + Page の\n汎用化（backend.md 推奨）は 2 つ目の paginated エンドポイントが\n出てきた時点で行う（YAGNI、CLAUDE.md §設計原則）。",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProblemSummaryResponse"
            },
            "title": "Items",
            "type": "array"
          },
          "page": {
            "title": "Page",
            "type": "integer"
          },
          "totalPages": {
            "title": "Totalpages",
            "type": "integer"
          }
        },
        "required": [
          "items",
          "page",
          "totalPages"
        ],
        "title": "ProblemListResponse",
        "type": "object"
      },
      "ProblemSummaryResponse": {
        "description": "問題一覧の 1 行分。タイトル / カテゴリ / 難易度のみで一覧 UI に必要十分。",
        "properties": {
          "category": {
            "$ref": "#/components/schemas/ProblemCategory"
          },
          "difficulty": {
            "$ref": "#/components/schemas/ProblemDifficulty"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "category",
          "difficulty"
        ],
        "title": "ProblemSummaryResponse",
        "type": "object"
      },
      "SubmissionAcceptedResponse": {
        "description": "解答送信の受付完了。クライアントは submissionId を持って結果取得 API を叩く。",
        "properties": {
          "status": {
            "const": "pending",
            "default": "pending",
            "title": "Status",
            "type": "string"
          },
          "submissionId": {
            "format": "uuid",
            "title": "Submissionid",
            "type": "string"
          }
        },
        "required": [
          "submissionId"
        ],
        "title": "SubmissionAcceptedResponse",
        "type": "object"
      },
      "SubmissionCreateRequest": {
        "description": "解答送信リクエスト。",
        "properties": {
          "code": {
            "maxLength": 100000,
            "minLength": 1,
            "title": "Code",
            "type": "string"
          },
          "problemId": {
            "format": "uuid",
            "title": "Problemid",
            "type": "string"
          }
        },
        "required": [
          "problemId",
          "code"
        ],
        "title": "SubmissionCreateRequest",
        "type": "object"
      },
      "SubmissionFailureKind": {
        "enum": [
          "test_failed",
          "timeout",
          "oom",
          "syntax",
          "runtime"
        ],
        "title": "SubmissionFailureKind",
        "type": "string"
      },
      "SubmissionResultPayload": {
        "description": "採点完了時の結果ペイロード。Worker が submissions.result に書き込む形と一致。",
        "properties": {
          "durationMs": {
            "title": "Durationms",
            "type": "integer"
          },
          "failureKind": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SubmissionFailureKind"
              },
              {
                "type": "null"
              }
            ]
          },
          "passed": {
            "title": "Passed",
            "type": "boolean"
          },
          "testResults": {
            "items": {
              "$ref": "#/components/schemas/SubmissionTestResultItem"
            },
            "title": "Testresults",
            "type": "array"
          }
        },
        "required": [
          "passed",
          "durationMs"
        ],
        "title": "SubmissionResultPayload",
        "type": "object"
      },
      "SubmissionStatus": {
        "enum": [
          "pending",
          "graded",
          "failed"
        ],
        "title": "SubmissionStatus",
        "type": "string"
      },
      "SubmissionStatusResponse": {
        "description": "解答 + 採点結果。クライアントは pending の間ポーリングする。",
        "properties": {
          "gradedAt": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Gradedat"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "problemId": {
            "format": "uuid",
            "title": "Problemid",
            "type": "string"
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SubmissionResultPayload"
              },
              {
                "type": "null"
              }
            ]
          },
          "score": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          },
          "status": {
            "$ref": "#/components/schemas/SubmissionStatus"
          },
          "totalCount": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Totalcount"
          }
        },
        "required": [
          "id",
          "problemId",
          "status"
        ],
        "title": "SubmissionStatusResponse",
        "type": "object"
      },
      "SubmissionSummary": {
        "description": "解答履歴の 1 行分。問題タイトルまで含めて一覧 UI に必要十分。",
        "properties": {
          "gradedAt": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Gradedat"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "problemId": {
            "format": "uuid",
            "title": "Problemid",
            "type": "string"
          },
          "problemTitle": {
            "title": "Problemtitle",
            "type": "string"
          },
          "score": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          },
          "status": {
            "$ref": "#/components/schemas/SubmissionStatus"
          },
          "totalCount": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Totalcount"
          }
        },
        "required": [
          "id",
          "problemId",
          "problemTitle",
          "status"
        ],
        "title": "SubmissionSummary",
        "type": "object"
      },
      "SubmissionTestResultItem": {
        "description": "1 テストケース分の結果。passed=false の時に expected/actual/message が埋まる。",
        "properties": {
          "actual": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Actual"
          },
          "durationMs": {
            "title": "Durationms",
            "type": "integer"
          },
          "expected": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expected"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "passed": {
            "title": "Passed",
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "passed",
          "durationMs"
        ],
        "title": "SubmissionTestResultItem",
        "type": "object"
      },
      "SubmissionsListResponse": {
        "description": "解答履歴一覧 + ページネーション情報。",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/SubmissionSummary"
            },
            "title": "Items",
            "type": "array"
          },
          "page": {
            "title": "Page",
            "type": "integer"
          },
          "pageSize": {
            "title": "Pagesize",
            "type": "integer"
          },
          "totalPages": {
            "title": "Totalpages",
            "type": "integer"
          }
        },
        "required": [
          "items",
          "page",
          "pageSize",
          "totalPages"
        ],
        "title": "SubmissionsListResponse",
        "type": "object"
      },
      "UserResponse": {
        "description": "現在ログイン中のユーザー情報。GET /auth/me が返す形。\n\nsnake_case のモデル属性を camelCase で JSON 出力するよう alias を効かせる\n（Frontend の Hey API 生成型もそのまま camelCase になる）。",
        "properties": {
          "displayName": {
            "title": "Displayname",
            "type": "string"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "displayName"
        ],
        "title": "UserResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "AI Coding Drill API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/problems": {
      "get": {
        "description": "カテゴリ・難易度フィルタ付きで問題一覧を返す。\n\n- 認証不要（ゲスト閲覧可、problem-display-and-answer.md §ビジネスルール）\n- 並び順は created_at DESC（新着優先）\n- 0 件でも 200 + items=[] / totalPages=0 で返す",
        "operationId": "list_problems_api_problems_get",
        "parameters": [
          {
            "description": "カテゴリで絞り込み",
            "in": "query",
            "name": "category",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/ProblemCategory"
                },
                {
                  "type": "null"
                }
              ],
              "description": "カテゴリで絞り込み",
              "title": "Category"
            }
          },
          {
            "description": "難易度で絞り込み",
            "in": "query",
            "name": "difficulty",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/ProblemDifficulty"
                },
                {
                  "type": "null"
                }
              ],
              "description": "難易度で絞り込み",
              "title": "Difficulty"
            }
          },
          {
            "description": "ページ番号（1 始まり）",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "description": "ページ番号（1 始まり）",
              "minimum": 1,
              "title": "Page",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Problems",
        "tags": [
          "problems"
        ]
      }
    },
    "/api/problems/generate": {
      "post": {
        "description": "カテゴリ・難易度を受け取って生成ジョブを enqueue する。\n\n挙動：\n  - generation_requests へ 1 行 INSERT（status='pending'）\n  - jobs へ 1 行 INSERT + NOTIFY new_job を同一トランザクションで実行\n  - 202 で requestId を返す。実際の生成は Worker が非同期で処理する\n  - レート制限: 同一ユーザーで 1 分 / 5 回を超えると 429 を返す",
        "operationId": "request_problem_generation_api_problems_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProblemGenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemGenerateAcceptedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Request Problem Generation",
        "tags": [
          "problems"
        ]
      }
    },
    "/api/problems/generate/{request_id}": {
      "get": {
        "description": "生成リクエストの現在ステータスを返す。\n\n- 自分のリクエストでない / 存在しないリクエスト ID には 404 を返す\n  （他人のリクエストか存在しないかの区別は付けない、情報漏洩防止）\n- status='completed' の時のみ problemId フィールドが付く",
        "operationId": "get_problem_generation_status_api_problems_generate__request_id__get",
        "parameters": [
          {
            "description": "生成リクエストの ID",
            "in": "path",
            "name": "request_id",
            "required": true,
            "schema": {
              "description": "生成リクエストの ID",
              "format": "uuid",
              "title": "Request Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemGenerateStatusResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Problem Generation Status",
        "tags": [
          "problems"
        ]
      }
    },
    "/api/problems/{problem_id}": {
      "get": {
        "description": "問題詳細を返す。テストケース全体は返さず examples（公開用 1〜数件）のみ含む。\n\n- 認証不要（problem-display-and-answer.md §ビジネスルール）\n- 存在しない / ソフトデリート済みは 404\n- レスポンスから test_cases / reference_solution / judge_scores を完全に\n  落とすマスキングは ProblemDetailResponse のスキーマ定義で実施される",
        "operationId": "get_problem_detail_api_problems__problem_id__get",
        "parameters": [
          {
            "description": "問題の ID",
            "in": "path",
            "name": "problem_id",
            "required": true,
            "schema": {
              "description": "問題の ID",
              "format": "uuid",
              "title": "Problem Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Problem Detail",
        "tags": [
          "problems"
        ]
      }
    },
    "/api/submissions": {
      "get": {
        "description": "自分の解答履歴をページングで返す。\n\n並び順は created_at DESC（新着順）。problem_title まで含めて返すため\n一覧 UI 側は追加の問題詳細取得が不要。",
        "operationId": "list_my_submissions_api_submissions_get",
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "minimum": 1,
              "title": "Page",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "default": 20,
              "maximum": 100,
              "minimum": 1,
              "title": "Pagesize",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionsListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List My Submissions",
        "tags": [
          "submissions"
        ]
      },
      "post": {
        "description": "解答コードを受け付けて submissions 行を作成し、202 で submissionId を返す。\n\n挙動：\n  - 対象問題の存在確認（存在しない / soft delete 済みは 404）\n  - submissions に 1 行 INSERT（status='pending'）\n  - 同一トランザクション内で jobs に 1 行 INSERT + NOTIFY new_job\n  - レート制限: 1 ユーザー 1 分 / 20 回まで\n\nクライアントはレスポンスの submissionId を持って\nGET /api/submissions/:id をポーリングし、status が graded / failed に遷移するのを待つ。",
        "operationId": "submit_answer_api_submissions_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmissionCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionAcceptedResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit Answer",
        "tags": [
          "submissions"
        ]
      }
    },
