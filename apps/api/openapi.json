    "/auth/github": {
      "get": {
        "description": "OAuth フロー開始。state を発行し GitHub の認可画面へ 302 リダイレクトする。\n\nクエリ:\n  - next: ログイン後の戻り先（同一オリジン相対パスのみ）。state レコードに\n          同梱して Redis に保存し、callback 側で 1 回使い切りで取り出す。\n          旧実装は別 Cookie（auth_next）で運んでいたが「state と next が\n          別場所に分かれて弱く結合」する設計弱点があったため state レコード\n          側に集約した。",
        "operationId": "start_github_oauth_auth_github_get",
        "parameters": [
          {
            "in": "query",
            "name": "next",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Next"
            }
          }
        ],
        "responses": {
          "302": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "GitHub 認可画面へリダイレクト"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Start Github Oauth",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/github/callback": {
      "get": {
        "description": "GitHub からのコールバック。\n\n成功時：Set-Cookie で sid / csrf_token を発行してホーム（または ?next= 指定先）へ 302。\nstate 不一致 / 期限切れ / 再使用：/login?auth_error=state_invalid へ 302。\nGitHub が ?error= を返した時：/login?auth_error=oauth_canceled へ 302。\nその他例外：/login?auth_error=oauth_failed へ 302。",
        "operationId": "github_callback_auth_github_callback_get",
        "parameters": [
          {
            "in": "query",
            "name": "code",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Code"
            }
          },
          {
            "in": "query",
            "name": "state",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "State"
            }
          },
          {
            "in": "query",
            "name": "error",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Error"
            }
          }
        ],
        "responses": {
          "302": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "ログイン成功はホーム /、失敗は /login へリダイレクト"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Github Callback",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "description": "セッションを破棄し、Cookie を Max-Age=0 で消す。\n\n- 内部的に Redis から `session:<sid>` を DELETE + `user:<id>:sessions` から SREM\n- 204 No Content（ボディなし）。Cookie だけがレスポンスヘッダーに残る",
        "operationId": "logout_auth_logout_post",
        "responses": {
          "204": {
            "description": "ログアウト成功（ボディなし）"
