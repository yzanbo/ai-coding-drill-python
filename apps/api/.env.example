# apps/api 用の環境変数テンプレート（コピーして .env を作成）
# pydantic-settings は変数名を case-insensitive で読むため、大文字 / 小文字どちらでも可。

# Postgres 接続（async ドライバ asyncpg を経由）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_coding_drill

# Redis 接続（cache / session / rate limit 用、ジョブキュー用途では使わない、ADR 0005）
REDIS_URL=redis://localhost:6379/0

# ---------- E2E 用接続情報（issue #86 で dev から完全分離） ----------
# 通常は `mise run e2e:up` / `mise run api:db-migrate:e2e` の task env が
# 自動上書きするので .env で切り替える必要はない。
# 素の alembic / psql を E2E DB に向けたい時の参考値としてコメントアウトで残す。
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ai_coding_drill_e2e
# REDIS_URL=redis://localhost:6380/0

# 実行環境（dev / test / staging / production）。
# production を指定すると、開発用既定値（SESSION_SIGNING_SECRET=dev-only-change-me /
# COOKIE_SECURE=false）が残っていた場合に起動時エラーになる安全装置が有効化される。
APP_ENV=dev

# ---------- GitHub OAuth ----------
# https://github.com/settings/developers で OAuth App を作成して値を取得。
# Authorization callback URL は GITHUB_REDIRECT_URI と一致させる必要がある。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# GitHub OAuth エンドポイント URL（既定は本番 github.com）。
# E2E テスト時のみ mock サーバ URL に上書きする想定。本番 / 開発ではコメントのまま。
# GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
# GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
# GITHUB_USER_API_URL=https://api.github.com/user

# ---------- セッション / Cookie ----------
# 本番は SESSION_SIGNING_SECRET に十分長いランダム文字列を入れる
# （例：python -c "import secrets; print(secrets.token_urlsafe(48))"）。
SESSION_COOKIE_NAME=session_id
CSRF_COOKIE_NAME=csrf_token
SESSION_TTL_SECONDS=604800
STATE_TTL_SECONDS=600
# ローカル http 開発時は false、本番は true
COOKIE_SECURE=false
SESSION_SIGNING_SECRET=dev-only-change-me

# ---------- Frontend ----------
FRONTEND_BASE_URL=http://localhost:3000
